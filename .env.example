# ════════════════════════════════════════════════════════════════════════════
# TYRO Forecast — environment configuration
# Copy this file to `.env` and fill in your tenant-specific values.
# `.env` is gitignored — never commit credentials to source control.
# ════════════════════════════════════════════════════════════════════════════

# ─── Azure AD App Registration ───
# Azure Portal → App registrations → "TYRO Forecast Web App"
# - Client ID: Application (client) ID
# - Tenant ID: Directory (tenant) ID
VITE_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# ─── PROD Dataverse (trader directory + main inventory) ───
# Power Platform admin center → Environment URL
VITE_DATAVERSE_URL=https://your-org.crm4.dynamics.com
VITE_DATAVERSE_ENTITY=mserp_tryaiinventoryagingreportentities

# ─── Historical Sales Dataverse (forecast data source) ───
# Tek environment kullanılıyorsa main URL ile aynı bırakılabilir.
VITE_HISTORICAL_DATAVERSE_URL=https://your-org.crm4.dynamics.com
VITE_HISTORICAL_SALES_ENTITY=mserp_tryhistoricalsalesdemandentities
